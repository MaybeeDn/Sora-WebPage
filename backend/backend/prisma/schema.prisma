// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  ADMIN
}

enum AreaType {
  LECTURA_CRITICA
  MATEMATICAS
  SOCIALES
  NATURALES
  INGLES
}

model Avatar {
  id Int @id @default(autoincrement())

  name     String
  imageUrl String

  users User[]

  createdAt DateTime @default(now())
}

model User {
  id Int @id @default(autoincrement())

  email        String @unique
  passwordHash String

  firstName String
  lastName  String

  role UserRole @default(STUDENT)

  avatarId Int?
  avatar   Avatar? @relation(fields: [avatarId], references: [id])

  workshopAttempts   WorkshopAttempt[]
  simulationAttempts SimulationAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Passage {
  id Int @id @default(autoincrement())

  title   String?
  content String

  questions Question[]

  createdAt DateTime @default(now())
}

model Question {
  id Int @id @default(autoincrement())

  area AreaType

  statement String

  imageUrl String?

  explanation String?

  difficulty Int?

  isActive Boolean @default(true)

  passageId Int?
  passage   Passage? @relation(fields: [passageId], references: [id])

  options QuestionOption[]

  workshopQuestions WorkshopQuestion[]
  workshopAnswers   WorkshopAnswer[]

  simulationAnswers SimulationAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuestionOption {
  id Int @id @default(autoincrement())

  questionId Int
  question   Question @relation(fields: [questionId], references: [id])

  label String

  text String?

  imageUrl String?

  isCorrect Boolean

  workshopAnswers WorkshopAnswer[]

  simulationAnswers SimulationAnswer[]

  createdAt DateTime @default(now())
}

model Workshop {
  id Int @id @default(autoincrement())

  title String

  area AreaType

  questions WorkshopQuestion[]

  attempts WorkshopAttempt[]

  createdAt DateTime @default(now())
}

model WorkshopQuestion {
  id Int @id @default(autoincrement())

  workshopId Int
  workshop   Workshop @relation(fields: [workshopId], references: [id])

  questionId Int
  question   Question @relation(fields: [questionId], references: [id])

  orderNumber Int
}

model WorkshopAttempt {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  workshopId Int
  workshop   Workshop @relation(fields: [workshopId], references: [id])

  startedAt DateTime @default(now())

  finishedAt DateTime?

  score Decimal?

  answers WorkshopAnswer[]
}

model WorkshopAnswer {
  id Int @id @default(autoincrement())

  attemptId Int
  attempt   WorkshopAttempt @relation(fields: [attemptId], references: [id])

  questionId Int
  question   Question @relation(fields: [questionId], references: [id])

  selectedOptionId Int?
  selectedOption   QuestionOption? @relation(fields: [selectedOptionId], references: [id])

  isCorrect Boolean?

  answeredAt DateTime @default(now())
}

model Simulation {
  id Int @id @default(autoincrement())

  title String

  totalQuestions Int

  attempts SimulationAttempt[]

  createdAt DateTime @default(now())
}

model SimulationAttempt {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  simulationId Int
  simulation   Simulation @relation(fields: [simulationId], references: [id])

  startedAt DateTime @default(now())

  finishedAt DateTime?

  globalScore Decimal?

  answers SimulationAnswer[]
}

model SimulationAnswer {
  id Int @id @default(autoincrement())

  attemptId Int
  attempt   SimulationAttempt @relation(fields: [attemptId], references: [id])

  questionId Int
  question   Question @relation(fields: [questionId], references: [id])

  selectedOptionId Int?
  selectedOption   QuestionOption? @relation(fields: [selectedOptionId], references: [id])

  isCorrect Boolean?

  answeredAt DateTime @default(now())
}
